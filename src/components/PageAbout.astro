<style>
  @import url("https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap");

  .polaroid-caption {
    font-family: "Caveat", cursive;
    font-size: 1.35rem;
    line-height: 1.15;
  }

  .polaroid-stack {
    perspective: 1000px;
  }

  /* Resting transforms — kept in sync with the keyframes in the script below.
     Declared here so the stack renders correctly before JS hydrates (no FOUC). */
  .polaroid {
    transform-origin: center;
    will-change: transform;
  }
  .polaroid[data-role="front"] {
    transform: translateX(40px) rotate(3deg) scale(1);
  }
  .polaroid[data-role="back"] {
    transform: translateX(-40px) translateY(18px) rotate(-6deg) scale(0.9);
  }
</style>

<style lang="scss" is:global>
  .wealthsimple {
    border-color: var(--color-slate-200);
    background-color: var(--color-slate-100);
    color: var(--color-slate-700);
  }
  .vendasta {
    border-color: var(--color-green-200);
    background-color: var(--color-green-100);
    color: var(--color-green-700);
  }
  .cisco {
    border-color: var(--color-blue-200);
    background-color: var(--color-blue-100);
    color: var(--color-blue-700);
  }
  .gr1d {
    border-color: var(--color-gray-200);
    background-color: var(--color-gray-100);
    color: var(--color-gray-700);
  }
  .vc {
    border-color: var(--color-slate-200);
    background-color: var(--color-slate-100);
    color: var(--color-slate-700);
  }
  .smileio {
    border-color: var(--color-yellow-200);
    background-color: var(--color-yellow-100);
    color: var(--color-yellow-700);
  }
</style>

<script>
  import { animate } from "motion";

  // Circular arc keyframes. Animating individual transform components (instead
  // of a raw transform string) lets Motion interpolate cleanly. rotateY adds a
  // 3D tilt against the stack's perspective so the swap reads as depth.
  // The incoming card swings up-and-over from the back slot to the front slot.
  const ARC_TO_FRONT = {
    x: [-40, -95, -10, 40],
    y: [18, -35, -45, 0],
    rotate: [-6, -2, 6, 3],
    scale: [0.9, 0.98, 1.07, 1],
    rotateY: [0, 22, -6, 0],
  };

  // The outgoing card sinks back along a shallower inward arc.
  const ARC_TO_BACK = {
    x: [40, 55, -40],
    y: [0, -10, 18],
    rotate: [3, 4, -6],
    scale: [1, 1, 0.9],
    rotateY: [0, -14, 0],
  };

  let animating = false;

  function bringToFront(clicked: HTMLElement) {
    if (animating || clicked.dataset.role === "front") return;
    const stack = clicked.closest(".polaroid-stack");
    const other = stack?.querySelector<HTMLElement>(
      '.polaroid[data-role="front"]',
    );
    if (!other) return;

    const clickedSlot = clicked.parentElement as HTMLElement;
    const otherSlot = other.parentElement as HTMLElement;

    animating = true;
    // Raise the incoming card above during the swing.
    clickedSlot.style.zIndex = "30";
    otherSlot.style.zIndex = "20";

    animate(clicked, ARC_TO_FRONT, {
      duration: 0.7,
      ease: [0.34, 1.2, 0.64, 1],
    });

    const back = animate(other, ARC_TO_BACK, {
      duration: 0.7,
      ease: [0.4, 0, 0.2, 1],
    });

    back.finished.then(() => {
      clicked.dataset.role = "front";
      other.dataset.role = "back";
      clickedSlot.style.zIndex = "20";
      otherSlot.style.zIndex = "10";
      animating = false;
    });
  }

  // Event delegation on document survives Astro view transitions.
  document.addEventListener("click", (e) => {
    const fig = (e.target as HTMLElement)?.closest<HTMLElement>(".polaroid");
    if (fig) bringToFront(fig);
  });
</script>
